# Kaiton — AI Running Coach
# Copy this file to .env.local and fill in your values
# Or configure everything through the onboarding wizard in the app

# Optional: Set your API key here instead of through the UI
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Strava Integration
# Kaiton includes a shared Strava app by default — no config needed.
# Only set these if you want to use your own Strava app:
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=
